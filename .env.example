# Nexus SaaS — Environment Configuration
# Copy to .env and adjust for your environment
# NEVER commit .env to version control — it is in .gitignore

# ── Security ──
SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_ISSUER=Nexus

# ── Database ──
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev
POSTGRES_DB=nexus
DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev@postgres:5432/nexus
REDIS_URL=redis://redis:6379/0

# ── pgAdmin ──
PGADMIN_EMAIL=admin@nexus.local
PGADMIN_PASSWORD=admin

# ── Ports (367x range) ──
PORT_API=3670
PORT_POSTGRES=3671
PORT_REDIS=3672
PORT_PGADMIN=3673
PORT_MAILPIT_UI=3674
PORT_MAILPIT_SMTP=3675
PORT_FRONTEND=3676

# ── Email (Mailpit in dev) ──
SMTP_HOST=mailpit
SMTP_PORT=1025
EMAIL_FROM=noreply@nexus.wesell.ro

# ── Domains ──
BASE_DOMAIN=nexus.wesell.ro
API_DOMAIN=api-nexus.wesell.ro

# ── Deployment Servers ──
# Beta / Staging
DEPLOY_HOST_BETA=192.168.1.31
DEPLOY_PATH_BETA=/home/projects/nexus.ro/beta
DEPLOY_HOST_STAGE=192.168.1.31
DEPLOY_PATH_STAGE=/home/projects/nexus.ro/stage
DEPLOY_USER_BETA=          # optional: defaults to $USER
DEPLOY_USER_STAGE=         # optional: defaults to $USER
# Production
DEPLOY_HOST_LIVE=192.168.1.30
DEPLOY_PATH_LIVE=/mnt/hdd/proiecte/nexus.ro/live
DEPLOY_USER_LIVE=           # optional: defaults to $USER

# ── Rate Limiting ──
RATE_LIMIT_AUTH_FREE=30
RATE_LIMIT_CRUD_FREE=200
RATE_LIMIT_AUTH_PRO=100
RATE_LIMIT_CRUD_PRO=1000

# ── File Storage ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ── Observability ──
SENTRY_DSN=
PROMETHEUS_ENABLED=true
