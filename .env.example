# Nexus SaaS — Environment Configuration
# Copy to .env and adjust for your environment
# NEVER commit .env to version control

# Security
SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_ISSUER=Nexus

# Database
DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev@localhost:3671/nexus
DATABASE_URL_BETA=postgresql+asyncpg://nexus:nexus_beta@192.168.1.31:5432/nexus_beta
DATABASE_URL_STAGE=postgresql+asyncpg://nexus:nexus_stage@192.168.1.31:5432/nexus_stage
DATABASE_URL_LIVE=postgresql+asyncpg://nexus:nexus_live@192.168.1.30:5432/nexus_live

# Redis
REDIS_URL=redis://localhost:3672/0

# Email (Mailpit in dev)
SMTP_HOST=localhost
SMTP_PORT=3675
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@nexus.wesell.ro

# Deployments
# Dev: localhost, ports 3670-3679
# Beta: 192.168.1.31 /home/projects/nexus.ro/beta
# Stage: 192.168.1.31 /home/projects/nexus.ro/stage
# Live: 192.168.1.30 /mnt/hdd/proiecte/nexus.ro/live

# Domain & Tenants
BASE_DOMAIN=nexus.wesell.ro
API_DOMAIN=api-nexus.wesell.ro
TENANT_DOMAIN_PATTERN={company}.nexus.wesell.ro

# Rate Limiting
RATE_LIMIT_AUTH_FREE=30
RATE_LIMIT_CRUD_FREE=200
RATE_LIMIT_AUTH_PRO=100
RATE_LIMIT_CRUD_PRO=1000

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Observability
SENTRY_DSN=
PROMETHEUS_ENABLED=true
